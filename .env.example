# Database Configuration
# PostgreSQL with PGVector extension
DATABASE_URL=postgresql://raguser:ragpass123@localhost:5432/postgres

# Groq Configuration (Required)
# Get from https://console.groq.com/keys
GROQ_API_KEY=your-groq-api-key

# Model Selection
# Default chosen from Groq production models for strong text RAG quality
LLM_CHOICE=llama-3.3-70b-versatile

# Optional vision model used by vision_cli.py for image-aware questions
GROQ_VISION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct

# Embedding Model
# Local Hugging Face embedding model used for ingestion and search
EMBEDDING_MODEL=BAAI/bge-small-en-v1.5

# Optional: auto, cpu, cuda, or mps
EMBEDDING_DEVICE=auto

# Optional: override the query prefix used for retrieval-style embedding models
# EMBED_QUERY_INSTRUCTION=Represent this sentence for searching relevant passages:

# Development Settings
LOG_LEVEL=INFO
DEBUG_MODE=false
